# Discord bot token (Developer Portal → your app → Bot → Token)
DISCORD_TOKEN=

# Server (guild) ID your bot runs in
GUILD_ID=

# ID of the Discord CATEGORY new ticket channels get created under
TICKET_CATEGORY_ID=

# ID of the channel where closed-ticket transcripts get posted
TRANSCRIPT_CHANNEL_ID=

# ID of the ONE role that is allowed to see/manage tickets
STAFF_ROLE_ID=

# Auto-close settings (in hours, decimals allowed e.g. 0.5 = 30 min)
AUTO_CLOSE_HOURS=24
WARNING_HOURS_BEFORE=1

# Branding (all optional)
BRAND_NAME=Support
BRAND_LOGO=
BRAND_COLOR=1A6FFF

# Banner image on the /panel embed (the "CONTACT US" style image).
# Option 1: local file placed next to bot.py, e.g. banner.png
PANEL_IMAGE_FILE=banner.png
# Option 2: a hosted https:// URL instead (used only if PANEL_IMAGE_FILE is empty/missing)
PANEL_IMAGE_URL=
